# ================================================
# PLOT TWIST — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit the actual .env file.
# ================================================

# TMDB API (free tier): https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Redis connection (local dev default shown)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (Phase 2 — persistent user profiles)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/plottwist

# CORS — set to your real frontend domain before launch
ALLOWED_ORIGINS=http://localhost:5173,https://plottwist.app
